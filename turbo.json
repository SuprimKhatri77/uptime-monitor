{
  "$schema": "https://turborepo.dev/schema.json",
  "ui": "tui",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "inputs": ["$TURBO_DEFAULT$", ".env*"],
      "outputs": [".next/**", "!.next/cache/**", "server"],
      "env": ["NODE_ENV", "NEXT_PUBLIC_API_URL", "COOKIE_DOMAIN"]
    },
    "generate": {},
    "lint": {
      "dependsOn": ["^lint"]
    },
    "check-types": {
      "dependsOn": ["^check-types"]
    },
    "dev": {
      "cache": false,
      "persistent": true,
      "env": ["INTERNAL_API_URL", "NEXT_PUBLIC_API_URL"]
    }
  }
}
